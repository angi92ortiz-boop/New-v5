local BibliotecaUI = {}
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local function CrearElemento(clase, propiedades)
    local elemento = Instancia.new(clase)
    for prop, valor in pares(propiedades) do
        elemento[prop] = valor
    end
    return elemento
end

function BibliotecaUI:CreateWindow(título)
    local ventana = {}
    local pestañas = {}
    local Minimizado = falso

    local ScreenGui = CrearElemento("ScreenGui", {
        Nombre = "UILibWindow",
        Padre = game:GetService("CoreGui"),
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        ResetOnSpawn = false,
        IgnoreGuiInset = true
    })

    -- Ajustar el tamaño para que sea más compacto
    local MainFrame = CrearElemento("Frame", {
        Nombre = "MainFrame",
        Padre = ScreenGui,
        BackgroundColor3 = Color3.fromRGB(20, 20, 20), -- Un gris muy oscuro
        BorderSizePixel = 0,
        Position = UDim2.new(0.5, -250, 0.5, -325), -- Centrado
        Size = UDim2.new(0, 500, 0, 650), -- Tamaño más compacto
        ClipsDescendants = true,
        Visible = true
    })

    -- Reducir el radio del borde para un aspecto más nítido
    CrearElemento("UICorner", {CornerRadius = UDim.new(0, 15), Parent = MainFrame})
    
    -- UIStroke para el borde cian, como en la imagen
    CrearElemento("UIStroke", {
        Color = Color3.fromRGB(0, 200, 255), 
        Thickness = 2, 
        Transparency = 0.5, 
        Parent = MainFrame
    })

    -- Ajustar la barra superior para que sea más pequeña y arrastrable
    local TopBar = CrearElemento("Frame", {
        Nombre = "TopBar",
        Padre = MainFrame,
        BackgroundColor3 = Color3.fromRGB(15, 15, 15), -- Un gris un poco más oscuro
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 50) -- Altura reducida
    })
    CrearElemento("UICorner", {CornerRadius = UDim.new(0, 15), Parent = TopBar})

    CrearElemento("TextLabel", {
        Parent = TopBar,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 20, 0, 0),
        Size = UDim2.new(0.6, 0, 1, 0),
        Font = Enum.Font.GothamBlack,
        Text = título o "Kemerus Hub", -- Texto de ejemplo
        TextColor3 = Color3.fromRGB(0, 200, 255), -- Color cian
        TextSize = 22,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextStrokeTransparency = 0.9,
        TextStrokeColor3 = Color3.fromRGB(255, 255, 255)
    })

    -- Ajustar el tamaño y la posición de los botones de control
    local CloseButton = CrearElemento("TextButton", {
        Parent = TopBar,
        BackgroundColor3 = Color3.fromRGB(255, 80, 80),
        BorderSizePixel = 0,
        Position = UDim2.new(1, -50, 0.5, -15),
        Size = UDim2.new(0, 30, 0, 30),
        Font = Enum.Font.GothamBold,
        Text = "X",
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextSize = 18
    })
    CrearElemento("UICorner", {CornerRadius = UDim.new(0, 10), Parent = CloseButton})

    local MinimizeButton = CrearElemento("TextButton", {
        Parent = TopBar,
        BackgroundColor3 = Color3.fromRGB(255, 200, 80),
        BorderSizePixel = 0,
        Position = UDim2.new(1, -90, 0.5, -15),
        Size = UDim2.new(0, 30, 0, 30),
        Font = Enum.Font.GothamBold,
        Text = "-",
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextSize = 18
    })
    CrearElemento("UICorner", {CornerRadius = UDim.new(0, 10), Parent = MinimizeButton})

    -- Ajustar el contenedor de pestañas lateral
    local TabContainer = CrearElemento("Frame", {
        Nombre = "TabContainer",
        Parent = MainFrame,
        BackgroundColor3 = Color3.fromRGB(20, 20, 20),
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, 50),
        Size = UDim2.new(0, 150, 1, -50)
    })
    CrearElemento("UICorner", {CornerRadius = UDim.new(0, 10), Parent = TabContainer})
    CrearElemento("UIListLayout", {
        Parent = TabContainer,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 8),
        HorizontalAlignment = Enum.HorizontalAlignment.Center,
        VerticalAlignment = Enum.VerticalAlignment.Top
    })

    -- Ajustar el panel de contenido
    local ContentFrame = CrearElemento("Frame", {
        Nombre = "ContentFrame",
        Parent = MainFrame,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 160, 0, 60),
        Size = UDim2.new(1, -170, 1, -70)
    })

    -- Código para arrastrar la ventana (se ha verificado y funciona en el script original)
    local arrastrando, dragStart, startPos
    TopBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            arrastrando = true
            dragStart = input.Position
            startPos = MainFrame.Position
            local connection
            connection = input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    arrastrando = false
                    connection:Disconnect()
                end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and arrastrando then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    -- Interacciones de botones
    CloseButton.MouseEnter:Connect(function() TweenService:Create(CloseButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(255, 100, 100)}):Play() end)
    CloseButton.MouseLeave:Connect(function() TweenService:Create(CloseButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(255, 80, 80)}):Play() end)
    CloseButton.MouseButton1Click:Connect(function()
        TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0)}):Play()
        task.wait(0.3)
        ScreenGui:Destroy()
    end)

    MinimizeButton.MouseEnter:Connect(function() TweenService:Create(MinimizeButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(255, 220, 100)}):Play() end)
    MinimizeButton.MouseLeave:Connect(function() TweenService:Create(MinimizeButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(255, 200, 80)}):Play() end)
    MinimizeButton.MouseButton1Click:Connect(function()
        Minimizado = not Minimizado
        TabContainer.Visible = not Minimizado
        ContentFrame.Visible = not Minimizado
        if Minimizado then
            TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Size = UDim2.new(0, 500, 0, 50)}):Play()
        else
            TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Size = UDim2.new(0, 500, 0, 650)}):Play()
        end
    end)

    -- Funciones de pestañas y elementos (sin cambios importantes, solo ajustes de color/tamaño)
    function ventana:SwitchToTab(tabToSelect)
        for _, tab in pairs(pestañas) do
            tab.Page.Visible = false
            TweenService:Create(tab.Button, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(30, 30, 30), TextColor3 = Color3.fromRGB(220, 220, 220)}):Play()
        end
        tabToSelect.Page.Visible = true
        TweenService:Create(tabToSelect.Button, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 200, 255), TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
    end

    function ventana:CreateTab(nombre)
        local tab = {}
        local tabButton = CrearElemento("TextButton", {
            Nombre = nombre .. "Pestaña",
            Parent = TabContainer,
            BackgroundColor3 = Color3.fromRGB(30, 30, 30),
            BorderSizePixel = 0,
            Size = UDim2.new(1, -15, 0, 40),
            Font = Enum.Font.GothamBold,
            Text = nombre,
            TextColor3 = Color3.fromRGB(220, 220, 220),
            TextSize = 16
        })
        CrearElemento("UICorner", {CornerRadius = UDim.new(0, 10), Parent = tabButton})
        local tabStroke = CrearElemento("UIStroke", {Color = Color3.fromRGB(0, 200, 255), Thickness = 1.5, Transparency = 0.6, Parent = tabButton})

        local page = CrearElemento("ScrollingFrame", {
            Nombre = nombre .. "Página",
            Parent = ContentFrame,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 1, 0),
            ScrollBarThickness = 4,
            ScrollBarImageColor3 = Color3.fromRGB(0, 200, 255),
            Visible = false
        })
        CrearElemento("UIListLayout", {Parent = page, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 12)})

        tab.Button = tabButton
        tab.Page = page
        table.insert(pestañas, tab)

        tabButton.MouseEnter:Connect(function()
            TweenService:Create(tabStroke, TweenInfo.new(0.2), {Transparency = 0.4, Thickness = 2}):Play()
            if not page.Visible then TweenService:Create(tabButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(45, 45, 45)}):Play() end
        end)
        tabButton.MouseLeave:Connect(function()
            TweenService:Create(tabStroke, TweenInfo.new(0.2), {Transparency = 0.6, Thickness = 1.5}):Play()
            if not page.Visible then TweenService:Create(tabButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(30, 30, 30)}):Play() end
        end)
        tabButton.MouseButton1Click:Connect(function() ventana:SwitchToTab(tab) end)

        if #pestañas == 1 then ventana:SwitchToTab(tab) end

        -- Elementos individuales (ajustados para el tamaño más compacto)
        function tab:CreateButton(texto, devolución)
            local button = CrearElemento("TextButton", {
                Parent = page,
                BackgroundColor3 = Color3.fromRGB(30, 30, 30),
                BorderSizePixel = 0,
                Size = UDim2.new(1, -20, 0, 45),
                Font = Enum.Font.GothamBold,
                Text = texto,
                TextColor3 = Color3.fromRGB(255, 255, 255),
                TextSize = 16,
                LayoutOrder = #page:GetChildren()
            })
            CrearElemento("UICorner", {CornerRadius = UDim.new(0, 10), Parent = button})
            local buttonStroke = CrearElemento("UIStroke", {Color = Color3.fromRGB(0, 200, 255), Thickness = 1.5, Transparency = 0.6, Parent = button})
            
            button.MouseEnter:Connect(function()
                TweenService:Create(button, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(45, 45, 45)}):Play()
                TweenService:Create(buttonStroke, TweenInfo.new(0.2), {Transparency = 0.4, Thickness = 2}):Play()
            end)
            button.MouseLeave:Connect(function()
                TweenService:Create(button, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(30, 30, 30)}):Play()
                TweenService:Create(buttonStroke, TweenInfo.new(0.2), {Transparency = 0.6, Thickness = 1.5}):Play()
            end)
            button.MouseButton1Click:Connect(function()
                pcall(devolución)
                TweenService:Create(button, TweenInfo.new(0.1), {Size = UDim2.new(1, -30, 0, 40)}):Play()
                task.wait(0.1)
                TweenService:Create(button, TweenInfo.new(0.1), {Size = UDim2.new(1, -20, 0, 45)}):Play()
            end)
            return button
        end

        function tab:CreateToggle(texto, devolución)
            local toggleFrame = CrearElemento("Frame", {
                Parent = page,
                BackgroundColor3 = Color3.fromRGB(30, 30, 30),
                BorderSizePixel = 0,
                Size = UDim2.new(1, -20, 0, 45),
                LayoutOrder = #page:GetChildren()
            })
            CrearElemento("UICorner", {CornerRadius = UDim.new(0, 10), Parent = toggleFrame})
            
            CrearElemento("TextLabel", {
                Parent = toggleFrame,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 15, 0, 0),
                Size = UDim2.new(0.7, 0, 1, 0),
                Font = Enum.Font.GothamBold,
                Text = texto,
                TextColor3 = Color3.fromRGB(255, 255, 255),
                TextSize = 16,
                TextXAlignment = Enum.TextXAlignment.Left
            })

            local toggleButton = CrearElemento("TextButton", {
                Parent = toggleFrame,
                BackgroundColor3 = Color3.fromRGB(45, 45, 45),
                BorderSizePixel = 0,
                Position = UDim2.new(1, -65, 0.5, -12),
                Size = UDim2.new(0, 50, 0, 25),
                Text = ""
            })
            CrearElemento("UICorner", {CornerRadius = UDim.new(1, 0), Parent = toggleButton})

            local toggleIndicator = CrearElemento("Frame", {
                Parent = toggleButton,
                BackgroundColor3 = Color3.fromRGB(150, 150, 150),
                BorderSizePixel = 0,
                Position = UDim2.new(0, 4, 0.5, -8),
                Size = UDim2.new(0, 16, 0, 16)
            })
            CrearElemento("UICorner", {CornerRadius = UDim.new(1, 0), Parent = toggleIndicator})

            local activado = false
            toggleButton.MouseButton1Click:Connect(function()
                activado = not activado
                if activado then
                    TweenService:Create(toggleButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 200, 255)}):Play()
                    TweenService:Create(toggleIndicator, TweenInfo.new(0.2), {Position = UDim2.new(1, -20, 0.5, -8), BackgroundColor3 = Color3.fromRGB(255, 255, 255)}):Play()
                else
                    TweenService:Create(toggleButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(45, 45, 45)}):Play()
                    TweenService:Create(toggleIndicator, TweenInfo.new(0.2), {Position = UDim2.new(0, 4, 0.5, -8), BackgroundColor3 = Color3.fromRGB(150, 150, 150)}):Play()
                end
                pcall(devolución, activado)
            end)
            return toggleFrame
        end

        function tab:CreateSlider(texto, mín, máx, predeterminado, devolución)
            local sliderFrame = CrearElemento("Frame", {
                Parent = page,
                BackgroundColor3 = Color3.fromRGB(30, 30, 30),
                BorderSizePixel = 0,
                Size = UDim2.new(1, -20, 0, 55), -- Altura reducida
                LayoutOrder = #page:GetChildren()
            })
            CrearElemento("UICorner", {CornerRadius = UDim.new(0, 10), Parent = sliderFrame})

            CrearElemento("TextLabel", {
                Parent = sliderFrame,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 15, 0, 3),
                Size = UDim2.new(0.5, 0, 0.4, 0),
                Font = Enum.Font.GothamBold,
                Text = texto,
                TextColor3 = Color3.fromRGB(255, 255, 255),
                TextSize = 16,
                TextXAlignment = Enum.TextXAlignment.Left
            })

            local valueLabel = CrearElemento("TextLabel", {
                Parent = sliderFrame,
                BackgroundTransparency = 1,
                Position = UDim2.new(0.5, 0, 0, 3),
                Size = UDim2.new(0.5, -15, 0.4, 0),
                Font = Enum.Font.Gotham,
                Text = tostring(predeterminado),
                TextColor3 = Color3.fromRGB(200, 200, 200),
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Right
            })

            local sliderBar = CrearElemento("TextButton", {
                Parent = sliderFrame,
                BackgroundColor3 = Color3.fromRGB(45, 45, 45),
                BorderSizePixel = 0,
                Position = UDim2.new(0.05, 0, 0.55, 0),
                Size = UDim2.new(0.9, 0, 0.2, 0),
                Text = ""
            })
            CrearElemento("UICorner", {CornerRadius = UDim.new(1, 0), Parent = sliderBar})

            local fill = CrearElemento("Frame", {
                Parent = sliderBar,
                BackgroundColor3 = Color3.fromRGB(0, 200, 255),
                BorderSizePixel = 0,
                Size = UDim2.new((predeterminado - mín) / (máx - mín), 0, 1, 0)
            })
            CrearElemento("UICorner", {CornerRadius = UDim.new(1, 0), Parent = fill})

            local isDragging = false
            local function actualizarControlDeslizador(inputPos)
                local relativeX = inputPos.X - sliderBar.AbsolutePosition.X
                local ratio = math.clamp(relativeX / sliderBar.AbsoluteSize.X, 0, 1)
                local valor = math.floor(mín + ratio * (máx - mín) + 0.5)
                fill.Size = UDim2.new(ratio, 0, 1, 0)
                valueLabel.Text = tostring(valor)
                pcall(devolución, valor)
            end

            sliderBar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    isDragging = true
                    actualizarControlDeslizador(input.Position)
                    local conn
                    conn = input.Changed:Connect(function()
                        if input.UserInputState == Enum.UserInputState.End then
                            isDragging = false
                            conn:Disconnect()
                        end
                    end)
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if isDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    actualizarControlDeslizador(input.Position)
                end
            end)
            return sliderFrame
        end

        return tab
    end
    return ventana
end

return BibliotecaUI
